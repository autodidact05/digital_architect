# ── Application ──────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-in-production
JWT_EXPIRY_HOURS=8

# ── Authentication (hardcoded users for now) ─────────────────
AUTH_USERS=admin:admin123,dev:dev123
ADMIN_USERS=admin

# ── LLM Provider ─────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── LLM Models (all configurable) ────────────────────────────
ORCHESTRATOR_MODEL=gpt-4.1-mini
BE_AGENT_MODEL=gpt-4.1-nano
FE_AGENT_MODEL=gpt-4.1-nano
DB_AGENT_MODEL=gpt-4.1-nano
INFRA_AGENT_MODEL=gpt-4.1-nano
MERGE_AGENT_MODEL=gpt-4o
EVALUATOR_MODEL=gpt-5.1
EMAIL_AGENT_MODEL=gpt-4.1-nano

# ── LLM Parameters ───────────────────────────────────────────
MAX_TOKENS=4096
TEMPERATURE=0.1
EVALUATOR_MAX_TOKENS=1024
MAX_EVAL_ITERATIONS=3

# ── ChromaDB ─────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/database/vector_db
CHROMA_COLLECTION_NAME=langchain
CHROMA_TOP_K=5
EMBEDDING_MODEL=text-embedding-3-large

# ── SQLite Audit DB ──────────────────────────────────────────
SQLITE_DB_PATH=./data/database/audit_db/audit.db

# ── SendGrid / Email Agent ───────────────────────────────────
SENDGRID_API_KEY=SG.xxx
SENDGRID_FROM_EMAIL=verified-sender@example.com
EMAIL_FROM=assistant@example.com
EMAIL_FROM_NAME=DigitalArchitect Assistant
ARCHITECT_TEAM_EMAIL=architecture-team@example.com

# ── Evaluation Thresholds ────────────────────────────────────
EVAL_PASS_THRESHOLD=0.75
EVAL_CONFIDENCE_THRESHOLD=0.6

# ── CORS ─────────────────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:3000
